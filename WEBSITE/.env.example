# Browser-visible Vite configuration. Never put passwords, tokens, API keys,
# database URLs, OAuth secrets, or peppers in any VITE_ variable.

# Production must stay empty to use same-origin /api requests.
VITE_MCDEPLOY_API_URL=

# Development only: local target for Vite's /api proxy.
VITE_MCDEPLOY_DEV_DAEMON=http://localhost:8082

# Server-side Netlify Function variables. Configure real values in the Netlify UI;
# these sanitized placeholders are documentation only and must not be committed as secrets.
RESEND_API_KEY=<server-only-resend-api-key>
RESEND_FROM="MCDeploy <info@mcdeploy.online>"
SESSION_PEPPER=<server-only-random-value-at-least-32-characters>
VERIFICATION_PEPPER=<different-server-only-random-value-at-least-32-characters>
RATE_LIMIT_PEPPER=<different-server-only-random-value-at-least-32-characters>
AGENT_ENROLLMENT_SECRET=<different-server-only-random-value-at-least-32-characters>
PUBLIC_SITE_URL=https://your-domain.example

# Optional, server-side only. Do not set or advertise a provider until its complete
# OAuth start/callback/state/identity-linking flow has been implemented and deployed.
GOOGLE_CLIENT_ID=<optional-server-only-client-id>
GOOGLE_CLIENT_SECRET=<optional-server-only-client-secret>
GITHUB_CLIENT_ID=<optional-server-only-client-id>
GITHUB_CLIENT_SECRET=<optional-server-only-client-secret>
DISCORD_CLIENT_ID=<optional-server-only-client-id>
DISCORD_CLIENT_SECRET=<optional-server-only-client-secret>

# Netlify Database connectivity is injected for Functions. Never copy a database
# connection string into this file or into a VITE_ variable.